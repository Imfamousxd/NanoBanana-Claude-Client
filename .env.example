# ─────────────────────────────────────────────────────────────────────────────
# Content-gen engine — environment keys
# Copy this file to `.env` and fill in your own keys. `.env` is gitignored.
# Only the three keys below are needed for content generation.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — gpt-image-2 image generation & editing (gpt-image.mjs + most *.mjs scripts).
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the OpenAI image model (default: gpt-image-2). Use gpt-image-1 only if needed.
# OPENAI_IMAGE_MODEL=gpt-image-2

# Google Gemini — "Nano Banana Pro" still images (nanobanana.mjs) AND Veo 3.1 video (nanobanana-video.mjs).
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Replicate — Seedance video models (the *seedance*/video scripts). Optional unless you generate video on Replicate.
# Get one at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your-replicate-token-here

# Optional: where generated files are written (default: ./generations)
# OUTPUT_DIR=generations
